{
  "name": "pingwire-api-documentation",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://docs.pingwire.io",
  "type": "module",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redoc": "^2.5.2",
    "styled-components": "^5.3.3"
  },
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "dev": "vite",
    "build": "npm run bundle && vite build",
    "preview": "vite preview",
    "bundle": "redocly bundle --config=.redocly.yml pingwire -o ./public/open-api-bundle.yml --force",
    "test": "npm run bundle && redocly lint --config=.redocly.yml pingwire-bundled"
  },
  "devDependencies": {
    "@redocly/cli": "^2.15.0",
    "@swc/core": "^1.3.96",
    "@vitejs/plugin-react-swc": "^3.4.0",
    "vite": "^5.0.0",
    "gh-pages": "^6.3.0"
  }
}
